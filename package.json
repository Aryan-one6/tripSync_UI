{
  "name": "tripsync",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:migrate": "npm run migrate --workspace=apps/api",
    "db:deploy": "npm run migrate:deploy --workspace=apps/api",
    "db:generate": "npm run generate --workspace=apps/api",
    "db:studio": "npm run studio --workspace=apps/api",
    "db:seed": "npm run seed --workspace=apps/api"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.2"
  },
  "packageManager": "npm@11.7.0",
  "engines": {
    "node": "20.x"
  }
}
