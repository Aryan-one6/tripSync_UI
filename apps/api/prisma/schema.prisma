generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum LoyaltyEventType {
  referral_inviter_bonus
  referral_new_user_bonus
  successful_trip_bonus
  redemption
  expiry
  manual_adjustment
}

enum VerificationTier {
  BASIC
  VERIFIED
  TRUSTED
}

enum PlanStatus {
  DRAFT
  OPEN
  CONFIRMING
  CONFIRMED
  COMPLETED
  EXPIRED
  CANCELLED
}

enum OfferStatus {
  PENDING
  COUNTERED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum MemberStatus {
  INTERESTED
  APPROVED
  COMMITTED
  LEFT
  REMOVED
}

enum MemberRole {
  CREATOR
  MEMBER
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
}

enum EscrowStatus {
  HELD
  PARTIAL_RELEASE
  RELEASED
  REFUNDED
}

enum FollowTargetType {
  USER
  AGENCY
}

enum ProfileViewTargetType {
  USER
  AGENCY
}

enum PaymentSource {
  PLAN_OFFER
  PACKAGE
}

enum TransferStatus {
  QUEUED
  PROCESSING
  SETTLED
  FAILED
  MANUAL
}

enum WalletPayoutMode {
  TRUST
  PRO
}

enum AgencyMemberRole {
  ADMIN
  MANAGER
  AGENT
  FINANCE
}

enum DisputeStatus {
  OPEN
  EVIDENCE_REQUIRED
  RESOLVED
  REJECTED
  SPLIT_REFUND
}

enum DisputeResolution {
  USER_FAVOR
  AGENCY_FAVOR
  SPLIT
}

enum RiskFlagType {
  CONTACT_SHARING
  PAYMENT_BYPASS
  CANCELLATION_ABUSE
  PAYMENT_ANOMALY
  AGENCY_INACTIVITY
}

// ─── User & Agency ──────────────────────────────────────

model User {
  id                String           @id @default(uuid())
  phone             String           @unique
  username          String?          @unique
  email             String?          @unique
  passwordHash      String?
  fullName          String
  avatarUrl         String?
  dateOfBirth       DateTime?
  gender            String?          // male | female | other
  city              String?
  travelPreferences String?
  bio               String?
  verification      VerificationTier @default(BASIC)
  aadhaarHash       String?          // SHA-256, never raw
  completedTrips    Int              @default(0)
  avgRating         Float            @default(0)
  isActive          Boolean          @default(true)
  // Referral / Loyalty
  referralCode      String?          @unique  // user's own shareable code
  referredByUserId  String?                   // set once on signup if they used a code
  referralBonusPaid Boolean          @default(false)  // guard: inviter paid once
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  agency            Agency?
  createdPlans      Plan[]
  groupMembers      GroupMember[]
  payments          Payment[]
  reviewsGiven      Review[]         @relation("ReviewerRel")
  reviewsReceived   Review[]         @relation("TargetUserRel")
  chatMessages      ChatMessage[]
  directConversationParticipants DirectConversationParticipant[]
  directMessagesSent DirectMessage[] @relation("DirectMessageSender")
  following         Follow[]         @relation("FollowFollowerRel")
  followers         Follow[]         @relation("FollowTargetUserRel")
  notifications     Notification[]
  profileViewsMade  ProfileView[]    @relation("ProfileViewViewerRel")
  profileViewsOwned ProfileView[]    @relation("ProfileViewOwnerRel")
  profileViewsAsTarget ProfileView[] @relation("ProfileViewTargetUserRel")
  agencyMemberships AgencyMember[]
  disputesCreated   Dispute[]        @relation("DisputeCreatorRel")
  disputesUpdated   Dispute[]        @relation("DisputeResolverRel")
  crmProfiles       AgencyCustomer[]
  riskFlagsRaised   FraudRiskFlag[]  @relation("RiskFlagRaisedByRel")
  loyaltyLedger     LoyaltyPointsLedger[]

  @@index([referralCode])
  @@map("users")
}

model Agency {
  id              String   @id @default(uuid())
  ownerId         String   @unique
  owner           User     @relation(fields: [ownerId], references: [id])
  name            String
  slug            String   @unique
  logoUrl         String?
  description     String?
  gstin           String?
  pan             String?
  tourismLicense  String?
  address         String?
  city            String?
  state           String?
  phone           String?
  email           String?
  specializations Json?    // ["adventure", "honeymoon"]
  destinations    Json?    // ["himachal", "uttarakhand"]
  verification    String   @default("pending")
  avgRating       Float    @default(0)
  totalReviews    Int      @default(0)
  totalTrips      Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  packages        Package[]
  offers          Offer[]
  reviewsReceived Review[] @relation("TargetAgencyRel")
  followers       Follow[]
  members         AgencyMember[]
  wallet          AgencyWallet?
  invoices        Invoice[]
  disputes        Dispute[]
  trustProfile    AgencyTrustProfile?
  insuranceQuotes InsuranceQuote[]
  customers       AgencyCustomer[]
  campaigns       AgencyCampaign[]
  riskFlags       FraudRiskFlag[]
  profileViews    ProfileView[]    @relation("ProfileViewTargetAgencyRel")

  @@map("agencies")
}

// ─── Plan & Package ─────────────────────────────────────

model Plan {
  id               String      @id @default(uuid())
  creatorId        String
  creator          User        @relation(fields: [creatorId], references: [id])
  title            String
  slug             String      @unique
  destination      String
  destinationState String?
  startDate        DateTime?
  endDate          DateTime?
  isDateFlexible   Boolean     @default(false)
  budgetMin        Int?        // per person INR
  budgetMax        Int?
  groupSizeMin     Int         @default(4)
  groupSizeMax     Int         @default(15)
  vibes            Json?       // ["adventure", "chill"]
  accommodation    String?     // hostel|budget|premium|camping
  groupType        String?     // friends|couples|solo|family|female_only
  genderPref       String?     // open|female_only|balanced
  ageRangeMin      Int?
  ageRangeMax      Int?
  activities       Json?       // ["trekking", "paragliding"]
  description      String?
  itinerary        Json?       // [{day,title,description,highlights,meals,accommodation,transport}]
  galleryUrls      Json?       // ["url1","url2"]
  coverImageUrl    String?
  autoApprove      Boolean     @default(false)
  status           PlanStatus  @default(DRAFT)
  expiresAt        DateTime?
  confirmedAt      DateTime?
  selectedOfferId  String?     @unique
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  group            Group?
  offers           Offer[]
  selectedOffer    Offer?      @relation("SelectedOfferRel", fields: [selectedOfferId], references: [id])

  @@index([status])
  @@index([destination])
  @@index([startDate, endDate])
  @@map("plans")
}

model Package {
  id                 String     @id @default(uuid())
  agencyId           String
  agency             Agency     @relation(fields: [agencyId], references: [id])
  title              String
  slug               String     @unique
  destination        String
  destinationState   String?
  itinerary          Json?      // [{day,title,description}]
  startDate          DateTime?
  endDate            DateTime?
  departureDates     Json?      // multiple date slots
  basePrice          Int        // per person INR
  pricingTiers       Json?      // [{minPax,price}]
  groupSizeMin       Int        @default(4)
  groupSizeMax       Int        @default(20)
  inclusions         Json?      // {transport,meals,activities}
  exclusions         String?
  accommodation      String?
  vibes              Json?
  activities         Json?
  galleryUrls        Json?      // ["url1","url2"]
  cancellationPolicy String?
  cancellationRules  Json?
  status             PlanStatus @default(DRAFT)
  expiresAt          DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  group              Group?

  @@index([status])
  @@index([destination])
  @@index([basePrice])
  @@map("packages")
}

// ─── Group, Offer & Negotiation ─────────────────────────

model Group {
  id          String        @id @default(uuid())
  planId      String?       @unique
  packageId   String?       @unique
  plan        Plan?         @relation(fields: [planId], references: [id])
  package     Package?      @relation(fields: [packageId], references: [id])
  currentSize Int           @default(0)
  maleCount   Int           @default(0)
  femaleCount Int           @default(0)
  otherCount  Int           @default(0)
  isLocked    Boolean       @default(false)
  paymentWindowEndsAt DateTime?
  createdAt   DateTime      @default(now())

  members     GroupMember[]
  payments    Payment[]
  reviews     Review[]
  messages    ChatMessage[]
  disputes    Dispute[]
  invoices    Invoice[]

  @@map("groups")
}

model GroupMember {
  id          String       @id @default(uuid())
  groupId     String
  userId      String
  group       Group        @relation(fields: [groupId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
  role        MemberRole   @default(MEMBER)
  status      MemberStatus @default(INTERESTED)
  joinedAt    DateTime     @default(now())
  committedAt DateTime?
  leftAt      DateTime?

  @@unique([groupId, userId])
  @@index([groupId, status])
  @@index([userId, status])
  @@map("group_members")
}

model Offer {
  id                 String      @id @default(uuid())
  planId             String
  agencyId           String
  plan               Plan        @relation(fields: [planId], references: [id])
  agency             Agency      @relation(fields: [agencyId], references: [id])
  pricePerPerson     Int
  pricingTiers       Json?
  inclusions         Json?
  itinerary          Json?
  cancellationPolicy String?
  cancellationRules  Json?
  validUntil         DateTime?
  status             OfferStatus @default(PENDING)
  isReferred         Boolean     @default(false)
  referredAt         DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  selectedByPlan     Plan?       @relation("SelectedOfferRel")
  negotiations       OfferNegotiation[]

  @@unique([planId, agencyId])
  @@index([planId, status])
  @@index([agencyId, isReferred, referredAt])
  @@map("offers")
}

model Follow {
  id             String           @id @default(uuid())
  followerUserId String
  targetType     FollowTargetType
  targetUserId   String?
  targetAgencyId String?
  createdAt      DateTime         @default(now())

  follower       User             @relation("FollowFollowerRel", fields: [followerUserId], references: [id], onDelete: Cascade)
  targetUser     User?            @relation("FollowTargetUserRel", fields: [targetUserId], references: [id], onDelete: Cascade)
  targetAgency   Agency?          @relation(fields: [targetAgencyId], references: [id], onDelete: Cascade)

  @@unique([followerUserId, targetUserId])
  @@unique([followerUserId, targetAgencyId])
  @@index([targetUserId])
  @@index([targetAgencyId])
  @@map("follows")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  href      String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt, createdAt(sort: Desc)])
  @@map("notifications")
}

model ProfileView {
  id                String                @id @default(uuid())
  viewerUserId      String
  targetOwnerUserId String
  targetType        ProfileViewTargetType
  targetUserId      String?
  targetAgencyId    String?
  createdAt         DateTime              @default(now())

  viewer            User                  @relation("ProfileViewViewerRel", fields: [viewerUserId], references: [id], onDelete: Cascade)
  targetOwner       User                  @relation("ProfileViewOwnerRel", fields: [targetOwnerUserId], references: [id], onDelete: Cascade)
  targetUser        User?                 @relation("ProfileViewTargetUserRel", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetAgency      Agency?               @relation("ProfileViewTargetAgencyRel", fields: [targetAgencyId], references: [id], onDelete: SetNull)

  @@index([targetOwnerUserId, createdAt(sort: Desc)])
  @@index([viewerUserId, createdAt(sort: Desc)])
  @@index([targetUserId])
  @@index([targetAgencyId])
  @@map("profile_views")
}

model OfferNegotiation {
  id              String   @id @default(uuid())
  offerId         String
  offer           Offer    @relation(fields: [offerId], references: [id])
  round           Int      // 1, 2, 3 (max 3)
  senderType      String   // user | agency
  price           Int?
  inclusionsDelta Json?
  message         String?
  createdAt       DateTime @default(now())

  @@map("offer_negotiations")
}

// ─── Payment, Review & Chat ─────────────────────────────

model Payment {
  id                 String        @id @default(uuid())
  userId             String
  groupId            String
  user               User          @relation(fields: [userId], references: [id])
  group              Group         @relation(fields: [groupId], references: [id])
  amount             Int           // in paise (100 paise = 1 INR)
  tripAmount         Int           @default(0)
  platformFeeAmount  Int           @default(0)
  feeGstAmount       Int           @default(0)
  commissionAmount   Int           @default(0)
  currency           String        @default("INR")
  source             PaymentSource @default(PLAN_OFFER)
  razorpayOrderId    String?
  razorpayPaymentId  String?
  status             PaymentStatus @default(PENDING)
  escrowStatus       EscrowStatus  @default(HELD)
  transferStatus     TransferStatus @default(QUEUED)
  transferReference  String?
  tranche1Released   Boolean       @default(false)
  tranche2Released   Boolean       @default(false)
  paidAt             DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  invoice            Invoice?
  dispute            Dispute?
  // Payout tracking (denormalized for display)
  agencyNetAmount    Int           @default(0)  // tripAmount * 0.9 (after 10% commission)
  initialPayout      Int           @default(0)  // 30% of agencyNetAmount released before trip
  finalPayout        Int           @default(0)  // 70% of agencyNetAmount released after trip
  // Loyalty / redemption tracking
  pointsRedeemed     Int           @default(0)  // in points (1 point = 1 INR)
  tripBonusIssued    Boolean       @default(false)  // guard: successful_trip_bonus

  @@index([userId, status])
  @@index([groupId, status])
  @@map("payments")
}

model Review {
  id              String   @id @default(uuid())
  reviewerId      String
  reviewer        User     @relation("ReviewerRel", fields: [reviewerId], references: [id])
  reviewType      String   // agency | co_traveler
  targetAgencyId  String?
  targetUserId    String?
  targetAgency    Agency?  @relation("TargetAgencyRel", fields: [targetAgencyId], references: [id])
  targetUser      User?    @relation("TargetUserRel", fields: [targetUserId], references: [id])
  groupId         String
  group           Group    @relation(fields: [groupId], references: [id])
  overallRating   Int      // 1-5
  safetyRating    Int      // 1-5
  valueRating     Int      // 1-5
  comment         String?
  createdAt       DateTime @default(now())

  @@unique([reviewerId, groupId, targetAgencyId])
  @@unique([reviewerId, groupId, targetUserId])
  @@map("reviews")
}

model ChatMessage {
  id          String   @id @default(uuid())
  groupId     String
  senderId    String?  // null = system message
  group       Group    @relation(fields: [groupId], references: [id])
  sender      User?    @relation(fields: [senderId], references: [id])
  messageType String   // text | system | poll | document
  content     String
  metadata    Json?    // poll options, doc url, etc.
  createdAt   DateTime @default(now())

  @@index([groupId, createdAt(sort: Desc)])
  @@index([groupId, messageType])
  @@map("chat_messages")
}

model DirectConversation {
  id          String                        @id @default(uuid())
  key         String                        @unique
  createdAt   DateTime                      @default(now())
  updatedAt   DateTime                      @updatedAt

  participants DirectConversationParticipant[]
  messages     DirectMessage[]

  @@map("direct_conversations")
}

model DirectConversationParticipant {
  id             String             @id @default(uuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  createdAt      DateTime           @default(now())

  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("direct_conversation_participants")
}

model DirectMessage {
  id             String             @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime           @default(now())

  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User               @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("direct_messages")
}

model AgencyMember {
  id         String           @id @default(uuid())
  agencyId   String
  userId     String
  role       AgencyMemberRole @default(AGENT)
  isActive   Boolean          @default(true)
  invitedBy  String?
  joinedAt   DateTime         @default(now())

  agency     Agency           @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([agencyId, userId])
  @@index([agencyId, role, isActive])
  @@map("agency_members")
}

model AgencyWallet {
  id               String           @id @default(uuid())
  agencyId         String           @unique
  pendingBalance   Int              @default(0)
  availableBalance Int              @default(0)
  totalEarned      Int              @default(0)
  totalCommission  Int              @default(0)
  securityDeposit  Int              @default(0)
  payoutMode       WalletPayoutMode @default(TRUST)
  updatedAt        DateTime         @updatedAt

  agency           Agency           @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  transactions     AgencyTransaction[]

  @@map("agency_wallets")
}

model AgencyTransaction {
  id                 String       @id @default(uuid())
  walletId           String
  type               String
  amount             Int
  description        String
  groupId            String?
  paymentId          String?
  razorpayTransferId String?
  createdAt          DateTime     @default(now())

  wallet             AgencyWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt(sort: Desc)])
  @@index([paymentId])
  @@map("agency_transactions")
}

model Invoice {
  id                String   @id @default(uuid())
  groupId           String
  paymentId         String   @unique
  agencyId          String
  userId            String
  invoiceNumber     String   @unique
  amount            Int
  platformFeeAmount Int      @default(0)
  feeGstAmount      Int      @default(0)
  commissionAmount  Int      @default(0)
  totalAmount       Int
  currency          String   @default("INR")
  status            String   @default("issued")
  pdfUrl            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  group             Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payment           Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  agency            Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("invoices")
}

model Dispute {
  id               String            @id @default(uuid())
  groupId          String
  paymentId        String            @unique
  agencyId         String
  createdByUserId  String
  reason           String
  status           DisputeStatus     @default(OPEN)
  resolution       DisputeResolution?
  resolutionNotes  String?
  resolvedByUserId String?
  resolvedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  group            Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payment          Payment           @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  agency           Agency            @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdBy        User              @relation("DisputeCreatorRel", fields: [createdByUserId], references: [id], onDelete: Cascade)
  resolvedBy       User?             @relation("DisputeResolverRel", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([agencyId, status, createdAt(sort: Desc)])
  @@index([createdByUserId, createdAt(sort: Desc)])
  @@map("disputes")
}

model AgencyTrustProfile {
  id                    String   @id @default(uuid())
  agencyId              String   @unique
  trustScore            Int      @default(0)
  eligibleForPro        Boolean  @default(false)
  completedTripsCount   Int      @default(0)
  averageRatingSnapshot Float    @default(0)
  recentDisputesCount   Int      @default(0)
  lastEvaluatedAt       DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  agency                Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("agency_trust_profiles")
}

model InsuranceQuote {
  id         String   @id @default(uuid())
  agencyId   String
  groupId    String?
  userId     String
  provider   String
  planCode   String?
  premium    Int?
  coverage   Int?
  status     String   @default("draft")
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  agency     Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("insurance_quotes")
}

model AgencyCustomer {
  id         String   @id @default(uuid())
  agencyId   String
  userId     String
  tags       Json?
  notes      String?
  lastTripAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  agency     Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([agencyId, userId])
  @@index([agencyId, createdAt(sort: Desc)])
  @@map("agency_customers")
}

model AgencyCampaign {
  id          String   @id @default(uuid())
  agencyId    String
  name        String
  description String?
  status      String   @default("draft")
  targetTags  Json?
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId, status, createdAt(sort: Desc)])
  @@map("agency_campaigns")
}

model FraudRiskFlag {
  id              String       @id @default(uuid())
  agencyId        String?
  userId          String?
  groupId         String?
  paymentId       String?
  messageId       String?
  type            RiskFlagType
  severity        String       @default("medium")
  details         Json?
  raisedByUserId  String?
  createdAt       DateTime     @default(now())
  resolvedAt      DateTime?
  resolutionNotes String?

  agency          Agency?      @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  raisedBy        User?        @relation("RiskFlagRaisedByRel", fields: [raisedByUserId], references: [id], onDelete: SetNull)

  @@index([agencyId, type, createdAt(sort: Desc)])
  @@index([userId, type, createdAt(sort: Desc)])
  @@index([groupId, createdAt(sort: Desc)])
  @@map("fraud_risk_flags")
}

// ─── Loyalty Points Ledger ───────────────────────────────

model LoyaltyPointsLedger {
  id          String           @id @default(uuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType   LoyaltyEventType
  points      Int              // positive = earn, negative = redeem/expire
  description String
  // Idempotency guard - prevents double-crediting the same event
  idempotencyKey String?       @unique
  // Source references
  groupId     String?          // trip that triggered the event
  paymentId   String?          // payment the redemption was applied to
  referredUserId String?       // for referral events
  // Expiry tracking
  expiresAt   DateTime?        // set on earn events; null on redemption/expiry rows
  expired     Boolean          @default(false)
  expiredAt   DateTime?
  createdAt   DateTime         @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, expired, expiresAt])
  @@index([idempotencyKey])
  @@map("loyalty_points_ledger")
}
