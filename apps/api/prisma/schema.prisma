generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                             String                          @id @default(uuid())
  phone                          String                          @unique
  email                          String?                         @unique
  fullName                       String
  avatarUrl                      String?
  dateOfBirth                    DateTime?
  gender                         String?
  city                           String?
  bio                            String?
  verification                   VerificationTier                @default(BASIC)
  aadhaarHash                    String?
  completedTrips                 Int                             @default(0)
  avgRating                      Float                           @default(0)
  isActive                       Boolean                         @default(true)
  createdAt                      DateTime                        @default(now())
  updatedAt                      DateTime                        @updatedAt
  username                       String?                         @unique
  passwordHash                   String?
  travelPreferences              String?
  referralCode                   String?
  referredByUserId               String?
  referralBonusPaid              Boolean                         @default(false)
  agency                         Agency?
  crmProfiles                    AgencyCustomer[]
  agencyMemberships              AgencyMember[]
  chatMessages                   ChatMessage[]
  directConversationParticipants DirectConversationParticipant[]
  directMessagesSent             DirectMessage[]                 @relation("DirectMessageSender")
  disputesCreated                Dispute[]                       @relation("DisputeCreatorRel")
  disputesUpdated                Dispute[]                       @relation("DisputeResolverRel")
  following                      Follow[]                        @relation("FollowFollowerRel")
  followers                      Follow[]                        @relation("FollowTargetUserRel")
  riskFlagsRaised                FraudRiskFlag[]                 @relation("RiskFlagRaisedByRel")
  groupMembers                   GroupMember[]
  loyaltyLedger                  LoyaltyPointsLedger[]
  notifications                  Notification[]
  payments                       Payment[]
  createdPlans                   Plan[]
  profileViewsOwned              ProfileView[]                   @relation("ProfileViewOwnerRel")
  profileViewsAsTarget           ProfileView[]                   @relation("ProfileViewTargetUserRel")
  profileViewsMade               ProfileView[]                   @relation("ProfileViewViewerRel")
  reviewsGiven                   Review[]                        @relation("ReviewerRel")
  reviewsReceived                Review[]                        @relation("TargetUserRel")
  referralLinks                  ReferralLink[]                  @relation("ReferralLinksCreated")
  referralsCreated               ReferralTransaction[]           @relation("ReferralTransactionsAsReferrer")
  referralsReceived              ReferralTransaction[]           @relation("ReferralTransactionsAsReferred")
  referralWallet                 ReferralWallet?  @relation("ReferralWallet")

  @@index([referralCode])
  @@map("users")
}

model Agency {
  id              String              @id @default(uuid())
  ownerId         String              @unique
  name            String
  slug            String              @unique
  logoUrl         String?
  description     String?
  gstin           String?             @unique
  pan             String?
  tourismLicense  String?
  address         String?
  city            String?
  state           String?
  phone           String?
  email           String?
  specializations Json?
  destinations    Json?
  verification    String              @default("pending")
  avgRating       Float               @default(0)
  totalReviews    Int                 @default(0)
  totalTrips      Int                 @default(0)
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  gstVerifiedAt   DateTime?
  gstVerifiedName String?
  owner           User                @relation(fields: [ownerId], references: [id])
  campaigns       AgencyCampaign[]
  customers       AgencyCustomer[]
  members         AgencyMember[]
  trustProfile    AgencyTrustProfile?
  wallet          AgencyWallet?
  disputes        Dispute[]
  followers       Follow[]
  riskFlags       FraudRiskFlag[]
  insuranceQuotes InsuranceQuote[]
  invoices        Invoice[]
  offers          Offer[]
  packages        Package[]
  profileViews    ProfileView[]       @relation("ProfileViewTargetAgencyRel")
  reviewsReceived Review[]            @relation("TargetAgencyRel")
  bankAccount     AgencyBankAccount?
  kycDocuments    KycDocument[]

  @@map("agencies")
}

model Plan {
  id                    String      @id @default(uuid())
  creatorId             String
  title                 String
  slug                  String      @unique
  destination           String
  destinationState      String?
  startDate             DateTime?
  endDate               DateTime?
  isDateFlexible        Boolean     @default(false)
  budgetMin             Int?
  budgetMax             Int?
  groupSizeMin          Int         @default(4)
  groupSizeMax          Int         @default(15)
  vibes                 Json?
  accommodation         String?
  groupType             String?
  genderPref            String?
  ageRangeMin           Int?
  ageRangeMax           Int?
  activities            Json?
  description           String?
  coverImageUrl         String?
  autoApprove           Boolean     @default(false)
  status                PlanStatus  @default(DRAFT)
  expiresAt             DateTime?
  confirmedAt           DateTime?
  selectedOfferId       String?     @unique
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  itinerary             Json?
  galleryUrls           Json?
  // ─── Corporate plan fields ──────────────────────────────────────
  planType              PlanType    @default(STANDARD)
  corporateTravelerCount  Int?
  hasBoardroomReq       Boolean     @default(false)
  hasConferenceReq      Boolean     @default(false)
  hasMeetingReq         Boolean     @default(false)
  corporateBudgetNotes  String?
  companySector         String?
  corporateRequirements Json?       // free-form extra requirements
  group                 Group?
  offers                Offer[]
  creator               User        @relation(fields: [creatorId], references: [id])
  selectedOffer         Offer?      @relation("SelectedOfferRel", fields: [selectedOfferId], references: [id])

  @@index([status])
  @@index([planType, status])
  @@index([destination])
  @@index([startDate, endDate])
  @@map("plans")
}

model Package {
  id                 String     @id @default(uuid())
  agencyId           String
  title              String
  slug               String     @unique
  destination        String
  destinationState   String?
  itinerary          Json?
  startDate          DateTime?
  endDate            DateTime?
  departureDates     Json?
  basePrice          Int
  pricingTiers       Json?
  groupSizeMin       Int        @default(4)
  groupSizeMax       Int        @default(20)
  inclusions         Json?
  exclusions         String?
  accommodation      String?
  vibes              Json?
  activities         Json?
  galleryUrls        Json?
  cancellationPolicy String?
  status             PlanStatus @default(DRAFT)
  expiresAt          DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  cancellationRules  Json?
  group              Group?
  agency             Agency     @relation(fields: [agencyId], references: [id])

  @@index([status])
  @@index([destination])
  @@index([basePrice])
  @@map("packages")
}

model Group {
  id                  String        @id @default(uuid())
  planId              String?       @unique
  packageId           String?       @unique
  currentSize         Int           @default(0)
  maleCount           Int           @default(0)
  femaleCount         Int           @default(0)
  otherCount          Int           @default(0)
  isLocked            Boolean       @default(false)
  createdAt           DateTime      @default(now())
  paymentWindowEndsAt DateTime?
  messages            ChatMessage[]
  disputes            Dispute[]
  members             GroupMember[]
  package             Package?      @relation(fields: [packageId], references: [id])
  plan                Plan?         @relation(fields: [planId], references: [id])
  invoices            Invoice[]
  payments            Payment[]
  reviews             Review[]

  @@map("groups")
}

model GroupMember {
  id          String       @id @default(uuid())
  groupId     String
  userId      String
  role        MemberRole   @default(MEMBER)
  status      MemberStatus @default(INTERESTED)
  joinedAt    DateTime     @default(now())
  committedAt DateTime?
  leftAt      DateTime?
  group       Group        @relation(fields: [groupId], references: [id])
  user        User         @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@index([groupId, status])
  @@index([userId, status])
  @@map("group_members")
}

model Offer {
  id                 String             @id @default(uuid())
  planId             String
  agencyId           String
  pricePerPerson     Int
  pricingTiers       Json?
  inclusions         Json?
  itinerary          Json?
  cancellationPolicy String?
  validUntil         DateTime?
  status             OfferStatus        @default(PENDING)
  isReferred         Boolean            @default(false)
  referredAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  cancellationRules  Json?
  negotiations       OfferNegotiation[]
  agency             Agency             @relation(fields: [agencyId], references: [id])
  plan               Plan               @relation(fields: [planId], references: [id])
  selectedByPlan     Plan?              @relation("SelectedOfferRel")

  @@unique([planId, agencyId])
  @@index([planId, status])
  @@index([agencyId, isReferred, referredAt])
  @@map("offers")
}

model Follow {
  id             String           @id @default(uuid())
  followerUserId String
  targetType     FollowTargetType
  targetUserId   String?
  targetAgencyId String?
  createdAt      DateTime         @default(now())
  follower       User             @relation("FollowFollowerRel", fields: [followerUserId], references: [id], onDelete: Cascade)
  targetAgency   Agency?          @relation(fields: [targetAgencyId], references: [id], onDelete: Cascade)
  targetUser     User?            @relation("FollowTargetUserRel", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([followerUserId, targetUserId])
  @@unique([followerUserId, targetAgencyId])
  @@index([targetUserId])
  @@index([targetAgencyId])
  @@map("follows")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  href      String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt, createdAt(sort: Desc)])
  @@map("notifications")
}

model ProfileView {
  id                String                @id @default(uuid())
  viewerUserId      String
  targetOwnerUserId String
  targetType        ProfileViewTargetType
  targetUserId      String?
  targetAgencyId    String?
  createdAt         DateTime              @default(now())
  targetAgency      Agency?               @relation("ProfileViewTargetAgencyRel", fields: [targetAgencyId], references: [id])
  targetOwner       User                  @relation("ProfileViewOwnerRel", fields: [targetOwnerUserId], references: [id], onDelete: Cascade)
  targetUser        User?                 @relation("ProfileViewTargetUserRel", fields: [targetUserId], references: [id])
  viewer            User                  @relation("ProfileViewViewerRel", fields: [viewerUserId], references: [id], onDelete: Cascade)

  @@index([targetOwnerUserId, createdAt(sort: Desc)])
  @@index([viewerUserId, createdAt(sort: Desc)])
  @@index([targetUserId])
  @@index([targetAgencyId])
  @@map("profile_views")
}

model OfferNegotiation {
  id              String   @id @default(uuid())
  offerId         String
  round           Int
  senderType      String
  price           Int?
  inclusionsDelta Json?
  message         String?
  createdAt       DateTime @default(now())
  offer           Offer    @relation(fields: [offerId], references: [id])

  @@map("offer_negotiations")
}

model Payment {
  id                String         @id @default(uuid())
  userId            String
  groupId           String
  amount            Int
  currency          String         @default("INR")
  razorpayOrderId   String?
  razorpayPaymentId String?
  status            PaymentStatus  @default(PENDING)
  escrowStatus      EscrowStatus   @default(HELD)
  tranche1Released  Boolean        @default(false)
  tranche2Released  Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  tripAmount        Int            @default(0)
  platformFeeAmount Int            @default(0)
  feeGstAmount      Int            @default(0)
  commissionAmount  Int            @default(0)
  source            PaymentSource  @default(PLAN_OFFER)
  transferStatus    TransferStatus @default(QUEUED)
  transferReference String?
  paidAt            DateTime?
  agencyNetAmount   Int            @default(0)
  initialPayout     Int            @default(0)
  finalPayout       Int            @default(0)
  pointsRedeemed    Int            @default(0)
  walletAmountUsed  Decimal        @default(0) @db.Decimal(12, 2)
  tripBonusIssued   Boolean        @default(false)
  agencyId          String?
  packageId         String?
  planId            String?
  dispute           Dispute?
  invoice           Invoice?
  group             Group          @relation(fields: [groupId], references: [id])
  user              User           @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([groupId, status])
  @@index([agencyId, status])
  @@index([planId])
  @@index([packageId])
  @@map("payments")
}

model Review {
  id             String   @id @default(uuid())
  reviewerId     String
  reviewType     String
  targetAgencyId String?
  targetUserId   String?
  groupId        String
  overallRating  Int
  safetyRating   Int
  valueRating    Int
  comment        String?
  createdAt      DateTime @default(now())
  group          Group    @relation(fields: [groupId], references: [id])
  reviewer       User     @relation("ReviewerRel", fields: [reviewerId], references: [id])
  targetAgency   Agency?  @relation("TargetAgencyRel", fields: [targetAgencyId], references: [id])
  targetUser     User?    @relation("TargetUserRel", fields: [targetUserId], references: [id])

  @@unique([reviewerId, groupId, targetAgencyId])
  @@unique([reviewerId, groupId, targetUserId])
  @@map("reviews")
}

model ChatMessage {
  id          String   @id @default(uuid())
  groupId     String
  senderId    String?
  messageType String
  content     String
  metadata    Json?
  createdAt   DateTime @default(now())
  group       Group    @relation(fields: [groupId], references: [id])
  sender      User?    @relation(fields: [senderId], references: [id])

  @@index([groupId, createdAt(sort: Desc)])
  @@index([groupId, messageType])
  @@map("chat_messages")
}

model DirectConversation {
  id           String                          @id @default(uuid())
  key          String                          @unique
  createdAt    DateTime                        @default(now())
  updatedAt    DateTime                        @default(now()) @updatedAt
  participants DirectConversationParticipant[]
  messages     DirectMessage[]

  @@map("direct_conversations")
}

model DirectConversationParticipant {
  id             String             @id @default(uuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  createdAt      DateTime           @default(now())
  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("direct_conversation_participants")
}

model DirectMessage {
  id             String             @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime           @default(now())
  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User               @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("direct_messages")
}

model AgencyMember {
  id        String           @id @default(uuid())
  agencyId  String
  userId    String
  role      AgencyMemberRole @default(AGENT)
  isActive  Boolean          @default(true)
  invitedBy String?
  joinedAt  DateTime         @default(now())
  agency    Agency           @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([agencyId, userId])
  @@index([agencyId, role, isActive])
  @@map("agency_members")
}

model AgencyWallet {
  id               String              @id @default(uuid())
  agencyId         String              @unique
  pendingBalance   Int                 @default(0)
  availableBalance Int                 @default(0)
  totalEarned      Int                 @default(0)
  totalCommission  Int                 @default(0)
  securityDeposit  Int                 @default(0)
  payoutMode       WalletPayoutMode    @default(TRUST)
  updatedAt        DateTime            @updatedAt
  transactions     AgencyTransaction[]
  agency           Agency              @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("agency_wallets")
}

model AgencyTransaction {
  id                 String       @id @default(uuid())
  walletId           String
  type               String
  amount             Int
  description        String
  groupId            String?
  paymentId          String?
  razorpayTransferId String?
  createdAt          DateTime     @default(now())
  wallet             AgencyWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt(sort: Desc)])
  @@index([paymentId])
  @@map("agency_transactions")
}

model Invoice {
  id                String   @id @default(uuid())
  groupId           String
  paymentId         String   @unique
  agencyId          String
  userId            String
  invoiceNumber     String   @unique
  amount            Int
  platformFeeAmount Int      @default(0)
  feeGstAmount      Int      @default(0)
  commissionAmount  Int      @default(0)
  totalAmount       Int
  currency          String   @default("INR")
  status            String   @default("issued")
  pdfUrl            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  agency            Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  group             Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payment           Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([agencyId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("invoices")
}

model Dispute {
  id               String             @id @default(uuid())
  groupId          String
  paymentId        String             @unique
  agencyId         String
  createdByUserId  String
  reason           String
  status           DisputeStatus      @default(OPEN)
  resolution       DisputeResolution?
  resolutionNotes  String?
  resolvedByUserId String?
  resolvedAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  agency           Agency             @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdBy        User               @relation("DisputeCreatorRel", fields: [createdByUserId], references: [id], onDelete: Cascade)
  group            Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payment          Payment            @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  resolvedBy       User?              @relation("DisputeResolverRel", fields: [resolvedByUserId], references: [id])

  @@index([agencyId, status, createdAt(sort: Desc)])
  @@index([createdByUserId, createdAt(sort: Desc)])
  @@map("disputes")
}

model AgencyTrustProfile {
  id                    String    @id @default(uuid())
  agencyId              String    @unique
  trustScore            Int       @default(0)
  eligibleForPro        Boolean   @default(false)
  completedTripsCount   Int       @default(0)
  averageRatingSnapshot Float     @default(0)
  recentDisputesCount   Int       @default(0)
  lastEvaluatedAt       DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  agency                Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("agency_trust_profiles")
}

model InsuranceQuote {
  id        String   @id @default(uuid())
  agencyId  String
  groupId   String?
  userId    String
  provider  String
  planCode  String?
  premium   Int?
  coverage  Int?
  status    String   @default("draft")
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("insurance_quotes")
}

model AgencyCustomer {
  id         String    @id @default(uuid())
  agencyId   String
  userId     String
  tags       Json?
  notes      String?
  lastTripAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  agency     Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([agencyId, userId])
  @@index([agencyId, createdAt(sort: Desc)])
  @@map("agency_customers")
}

model AgencyCampaign {
  id          String    @id @default(uuid())
  agencyId    String
  name        String
  description String?
  status      String    @default("draft")
  targetTags  Json?
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  agency      Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId, status, createdAt(sort: Desc)])
  @@map("agency_campaigns")
}

model FraudRiskFlag {
  id              String       @id @default(uuid())
  agencyId        String?
  userId          String?
  groupId         String?
  paymentId       String?
  messageId       String?
  type            RiskFlagType
  severity        String       @default("medium")
  details         Json?
  raisedByUserId  String?
  createdAt       DateTime     @default(now())
  resolvedAt      DateTime?
  resolutionNotes String?
  agency          Agency?      @relation(fields: [agencyId], references: [id])
  raisedBy        User?        @relation("RiskFlagRaisedByRel", fields: [raisedByUserId], references: [id])

  @@index([agencyId, type, createdAt(sort: Desc)])
  @@index([userId, type, createdAt(sort: Desc)])
  @@index([groupId, createdAt(sort: Desc)])
  @@map("fraud_risk_flags")
}

model LoyaltyPointsLedger {
  id             String           @id @default(uuid())
  userId         String
  eventType      LoyaltyEventType
  points         Int
  description    String
  idempotencyKey String?
  groupId        String?
  paymentId      String?
  referredUserId String?
  expiresAt      DateTime?
  expired        Boolean          @default(false)
  expiredAt      DateTime?
  createdAt      DateTime         @default(now())
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, expired, expiresAt])
  @@index([idempotencyKey])
  @@map("loyalty_points_ledger")
}

enum LoyaltyEventType {
  referral_inviter_bonus
  referral_new_user_bonus
  successful_trip_bonus
  redemption
  expiry
  manual_adjustment
}

enum VerificationTier {
  BASIC
  VERIFIED
  TRUSTED
}

enum PlanStatus {
  DRAFT
  OPEN
  CONFIRMING
  CONFIRMED
  COMPLETED
  EXPIRED
  CANCELLED
}

enum PlanType {
  STANDARD
  CORPORATE
}

enum OfferStatus {
  PENDING
  COUNTERED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum MemberStatus {
  INTERESTED
  APPROVED
  COMMITTED
  LEFT
  REMOVED
}

enum MemberRole {
  CREATOR
  MEMBER
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
}

enum EscrowStatus {
  HELD
  PARTIAL_RELEASE
  RELEASED
  REFUNDED
}

enum FollowTargetType {
  USER
  AGENCY
}

enum ProfileViewTargetType {
  USER
  AGENCY
}

enum PaymentSource {
  PLAN_OFFER
  PACKAGE
}

enum TransferStatus {
  QUEUED
  PROCESSING
  SETTLED
  FAILED
  MANUAL
}

enum WalletPayoutMode {
  TRUST
  PRO
}

enum AgencyMemberRole {
  ADMIN
  MANAGER
  AGENT
  FINANCE
}

enum DisputeStatus {
  OPEN
  EVIDENCE_REQUIRED
  RESOLVED
  REJECTED
  SPLIT_REFUND
}

enum DisputeResolution {
  USER_FAVOR
  AGENCY_FAVOR
  SPLIT
}

enum RiskFlagType {
  CONTACT_SHARING
  PAYMENT_BYPASS
  CANCELLATION_ABUSE
  PAYMENT_ANOMALY
  AGENCY_INACTIVITY
}

enum ReferralStatus {
  INVITED
  PENDING
  COMPLETED
}

enum ReferralWalletTransactionType {
  referral_earned
  checkout_spent
  admin_credit
  admin_debit
}

// ─── User Referral System ─────────────────────────────────────────────────────

model ReferralLink {
  id           String   @id @default(uuid())
  userId       String
  code         String   @unique @db.Char(8)
  expiresAt    DateTime
  usedAt       DateTime?
  usedByUserId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation("ReferralLinksCreated", fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([userId, expiresAt])
  @@map("referral_links")
}

model ReferralTransaction {
  id                 String          @id @default(uuid())
  referrerId         String
  referredUserId     String
  status             ReferralStatus  @default(INVITED)
  referrerCredited   Boolean         @default(false)
  referredCredited   Boolean         @default(false)
  idempotencyKey     String          @unique
  referrerAmount     Int             @default(25000) // ₹250 in paise
  referredAmount     Int             @default(15000) // ₹150 in paise
  completedAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  referrer           User            @relation("ReferralTransactionsAsReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser       User            @relation("ReferralTransactionsAsReferred", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@unique([referrerId, referredUserId])
  @@index([status, createdAt(sort: Desc)])
  @@map("referral_transactions")
}

// ─── User Wallet System ───────────────────────────────────────────────────────

model ReferralWallet {
  id               String                      @id @default(uuid())
  userId           String                      @unique
  balance          Decimal                     @default(0) @db.Decimal(12, 2)
  totalEarned      Decimal                     @default(0) @db.Decimal(12, 2)
  totalSpent       Decimal                     @default(0) @db.Decimal(12, 2)
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  user             User                        @relation("ReferralWallet", fields: [userId], references: [id], onDelete: Cascade)
  transactions     ReferralWalletTransaction[]

  @@map("referral_wallets")
}

model ReferralWalletTransaction {
  id             String                      @id @default(uuid())
  walletId       String
  type           ReferralWalletTransactionType
  amount         Decimal                     @db.Decimal(12, 2)
  description    String?
  referenceId    String? // referral_transaction_id
  referralId     String? // referral_transaction_id (for clarity)
  paymentId      String? // payment_id
  idempotencyKey String                      @unique
  createdAt      DateTime                    @default(now())
  wallet         ReferralWallet              @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, type, createdAt(sort: Desc)])
  @@index([referralId])
  @@index([paymentId])
  @@map("referral_wallet_transactions")
}

// ─── GST Verification Audit Log ───────────────────────────────────────────────

model GstVerificationLog {
  id          String   @id @default(uuid())
  gstin       String
  agencyId    String?
  requestedBy String?  // userId or IP
  verified    Boolean  @default(false)
  legalName   String?
  tradeName   String?
  status      String?
  errorMsg    String?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([gstin, createdAt(sort: Desc)])
  @@index([agencyId, createdAt(sort: Desc)])
  @@map("gst_verification_logs")
}

// ─── Agency Bank Account (Secure) ───────────────────────────────────────────

model AgencyBankAccount {
  id                    String         @id @default(uuid())
  agencyId              String         @unique
  encryptedAccountNumber String        // AES-256-GCM encrypted
  encryptedIfsc         String         // AES-256-GCM encrypted
  accountHolderName     String
  bankName              String?
  branchName            String?
  verificationStatus    BankVerificationStatus @default(PENDING)
  pennyDropReference    String?
  pennyDropAmount       Int?           // in paise
  nameMatchScore        Float?
  verifiedAt            DateTime?
  retryCount            Int            @default(0)
  lastAttemptAt         DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  agency                Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("agency_bank_accounts")
}

enum BankVerificationStatus {
  PENDING
  VERIFIED
  FAILED
  NAME_MISMATCH
  MAX_RETRIES_EXCEEDED
}

// ─── KYC Document Vault ───────────────────────────────────────────────────────

model KycDocument {
  id          String          @id @default(uuid())
  agencyId    String
  docType     KycDocumentType
  s3Key       String          // private S3 key — never exposed directly
  fileName    String
  mimeType    String
  status      String          @default("pending")  // pending | approved | rejected
  reviewedBy  String?         // admin userId
  reviewedAt  DateTime?
  reviewNotes String?
  uploadedAt  DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  agency      Agency          @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId, docType])
  @@map("kyc_documents")
}

enum KycDocumentType {
  PAN_CARD
  CANCELLED_CHEQUE
  GST_CERTIFICATE
  TOURISM_LICENSE
  OTHER
}

// ─── Promotional Discounts ────────────────────────────────────────────────────

model PromotionalDiscount {
  id                String    @id @default(uuid())
  code              String    @unique
  description       String?
  discountType      String    @default("flat")  // flat | percent
  discountValue     Int       // paise for flat, basis-points for percent (100 = 1%)
  maxUsageTotal     Int?
  maxUsagePerUser   Int       @default(1)
  usageCount        Int       @default(0)
  minOrderAmount    Int       @default(0)   // paise
  maxDiscountAmount Int?      // paise cap
  isActive          Boolean   @default(true)
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  usages            PromoCodeUsage[]

  @@index([code, isActive])
  @@map("promotional_discounts")
}

model PromoCodeUsage {
  id        String    @id @default(uuid())
  promoId   String
  userId    String
  paymentId String?
  discountApplied Int
  usedAt    DateTime  @default(now())
  promo     PromotionalDiscount @relation(fields: [promoId], references: [id])

  @@unique([promoId, userId])  // max 1 usage per user (enforced at DB level)
  @@index([userId])
  @@map("promo_code_usages")
}
