# Database
# Prisma Client on Vercel/serverless: use Supavisor transaction mode and disable prepared statements.
DATABASE_URL="postgresql://postgres.[project-ref]:password@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Prisma Migrate / Prisma Studio: use the direct database connection from the Supabase Connect panel.
DIRECT_URL="postgresql://postgres:password@db.[project-ref].supabase.co:5432/postgres"

# Redis
# Local development:
# REDIS_URL="redis://localhost:6379"
# Production/live:
# Use a managed Redis endpoint with TLS (example format below).
REDIS_URL="rediss://default:gQAAAAAAAXeIAAIncDJjZWFlM2I1NDZkMzA0ZGUwOTI3ZjZiYWM1N2Y5MDQ4MnAyOTYxMzY@amazed-gazelle-96136.upstash.io:6379"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"

# MSG91 (OTP)
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""

# DigiLocker eKYC
DIGILOCKER_VERIFY_URL=""
DIGILOCKER_CLIENT_ID=""
DIGILOCKER_CLIENT_SECRET=""

# GST verification fallback provider (gstincheck.co.in)
GSTINCHECK_API_KEY=""

# Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# WhatsApp Business Cloud API
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_API_VERSION="v22.0"

# AWS S3 / Cloudflare R2
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""

# App
PORT=4010
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# Supabase Auth (email verification)
# Project URL: https://<project-ref>.supabase.co
SUPABASE_URL=""
SUPABASE_ANON_KEY=""

# Zoho Business Email (SMTP)
# Use smtp.zoho.in  for accounts on India DC (travellersin.com)
# Use smtp.zoho.com for accounts on Global DC
# Sign in at https://mail.zoho.in → Settings → Mail Accounts → Configure SMTP
ZOHO_SMTP_HOST=smtp.zoho.in
ZOHO_SMTP_PORT=465
ZOHO_SMTP_SECURE=true
ZOHO_EMAIL="your-email@yourdomain.com"
ZOHO_EMAIL_PASSWORD="your-zoho-smtp-app-password"
APP_NAME="Travellers India"
